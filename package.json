{
  "name": "readingdaily-scripture-app",
  "version": "1.0.0",
  "description": "A React Native app for daily scripture reading with progress tracking and engagement features",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo build",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:preview": "eas build --platform all --profile preview",
    "build:production": "eas build --platform all --profile production",
    "submit:ios": "eas submit --platform ios --latest",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006"
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "8.2.0",
    "@react-native-picker/picker": "2.9.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "ajv": "^8.17.1",
    "expo": "52",
    "expo-asset": "~11.0.5",
    "expo-audio": "~0.3.5",
    "expo-av": "~15.0.2",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "~17.0.8",
    "expo-crypto": "~14.0.2",
    "expo-dev-client": "~5.0.20",
    "expo-device": "~7.0.3",
    "expo-font": "~13.0.4",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.5",
    "expo-local-authentication": "~15.0.2",
    "expo-network": "~7.0.5",
    "expo-notifications": "~0.29.14",
    "expo-router": "~4.0.21",
    "expo-secure-store": "~14.0.1",
    "expo-sqlite": "~15.1.4",
    "expo-store-review": "~8.0.1",
    "expo-updates": "~0.27.4",
    "firebase": "^12.3.0",
    "i18next": "^25.6.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "immer": "^10.2.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.46.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^16.3.0",
    "react-native": "0.76.9",
    "react-native-calendars": "^1.1313.0",
    "react-native-nitro-modules": "^0.29.8",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "~0.19.13",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.3",
    "@types/jest": "^29.5.11",
    "@types/react": "~18.3.12",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.6",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  }
}
